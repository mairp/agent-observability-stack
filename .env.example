# ---- agent-observability-stack: copy to .env and fill in ----
# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# OpenClaw gateway scrape (dedicated low-scope operator token)
# Endpoint that serves Prometheus text: https://<gateway>:18789/api/diagnostics/prometheus
OPENCLAW_GATEWAY_HOST=host.docker.internal
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_SCRAPE_TOKEN=replace-with-low-scope-operator-token

# Alertmanager -> Telegram (create a dedicated alert bot via @BotFather)
TELEGRAM_BOT_TOKEN=000000000:replace-with-bot-token
TELEGRAM_CHAT_ID=000000000

# Virtualization-host exporter (optional overlay) — API token for the hypervisor host
# Only used by docker-compose.override.yml; leave blank if unused.
PVE_TOKEN_ID=
PVE_TOKEN_SECRET=
PVE_HOST=host.docker.internal
PVE_VERIFY_SSL=false

# Retention
PROM_RETENTION=30d

# LiteLLM /metrics scrape (master key)
LITELLM_MASTER_KEY=sk-replace-me

# Browser-reachable Grafana base for grafy clickable links (e.g. http://<host>:3000); leave blank to omit links
GRAFANA_PUBLIC_URL=
